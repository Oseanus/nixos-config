{
  pkgs,
  ...
}:

{
  ##########################################################
  # Display Manager
  ##########################################################

  services.displayManager.sddm.enable = true;

  ##########################################################
  # KDE Plasma 6
  ##########################################################

  services.desktopManager.plasma6.enable = true;

  ##########################################################
  # Printing Support
  ##########################################################

  services.printing.enable = true;

  ##########################################################
  # Sound
  ##########################################################

  services.pipewire = {
    enable = true;
    pulse.enable = true;
    alsa.enable = true;
    alsa.support32Bit = true;
  };

  ##########################################################
  # Graphics
  ##########################################################

  hardware.graphics.enable = true;
}